# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string. On AWS RDS use the endpoint hostname.
DATABASE_URL="postgresql://pm_tool_user:strong_password@localhost:5432/pm_tool"

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-64-byte-random-hex
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=replace-with-different-64-byte-random-hex
JWT_REFRESH_EXPIRES_IN=7d

# ── Google OAuth (optional) ───────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# In production replace localhost with your actual domain
GOOGLE_CALLBACK_URL=https://your-domain.com/api/v1/auth/google/callback

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
# Must match the domain serving the frontend (no trailing slash)
FRONTEND_URL=https://your-domain.com

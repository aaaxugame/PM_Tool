generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── 1. Identity & Access ────────────────────────────────────────────────────

model User {
  id           Int          @id @default(autoincrement())
  email        String       @unique
  name         String
  passwordHash String?
  googleId     String?      @unique
  authProvider AuthProvider @default(LOCAL)
  isActive     Boolean      @default(true)
  jobTitle     String?
  createdAt    DateTime     @default(now())

  vendor   Vendor? @relation(fields: [vendorId], references: [id])
  vendorId Int?
  client   Client? @relation(fields: [clientId], references: [id])
  clientId Int?

  userRoles              UserRole[]
  projectAssignments     ProjectAssignment[] @relation("AssignmentUser")
  assignedProjectAssignments ProjectAssignment[] @relation("AssignmentAssignedBy")
  projectMembers         ProjectMember[]
  createdProjects        Project[]           @relation("ProjectCreatedBy")
  assignedTasks          Task[]              @relation("TaskAssignee")
  assignedByTasks        Task[]              @relation("TaskAssignedBy")
  createdTasks           Task[]              @relation("TaskCreatedBy")
  timesheets             Timesheet[]
  timeEntries            TimeEntry[]
  submittedQuotes        VendorQuote[]       @relation("QuoteSubmittedBy")
  reviewedQuotes         VendorQuote[]       @relation("QuoteReviewedBy")
  budgets                Budget[]
  createdInvoices        Invoice[]
  recordedPayments           Payment[]
  billingContactSettings     ProjectInvoiceSetting[]
  reviewedTimesheets         Timesheet[]         @relation("TimesheetReviewedBy")
  billingRates               BillingRate[]
  approvedInvoices           Invoice[]    @relation("InvoiceApprovedBy")

  @@map("users")
}

enum AuthProvider {
  LOCAL
  GOOGLE
}

model Role {
  id        Int        @id @default(autoincrement())
  name      RoleName   @unique
  userRoles UserRole[]

  @@map("roles")
}

enum RoleName {
  SUPER_ADMIN
  ADMIN
  ACCOUNT_MANAGER
  PROJECT_MANAGER
  TEAM_MEMBER
  CONTRACTOR
  VENDOR_CONTACT
  CLIENT
}

model UserRole {
  id     Int  @id @default(autoincrement())
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId Int
  role   Role @relation(fields: [roleId], references: [id])
  roleId Int

  @@unique([userId, roleId])
  @@map("user_roles")
}

// ─── 2. Organizations ────────────────────────────────────────────────────────

model Client {
  id           Int      @id @default(autoincrement())
  name         String
  contactEmail String?
  contactPhone String?
  address      String?
  currency     String   @default("USD")
  paymentTerms String   @default("Net 30")
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  users    User[]
  projects Project[]
  invoices Invoice[]

  @@map("clients")
}

model Vendor {
  id                Int      @id @default(autoincrement())
  name              String
  contactEmail      String?
  contactPhone      String?
  address           String?
  defaultHourlyRate Decimal? @db.Decimal(10, 2)
  currency          String   @default("USD")
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())

  users             User[]
  vendorQuotes      VendorQuote[]
  billingRates      BillingRate[]
  invoices          Invoice[]
  requestedProjects Project[] @relation("ProjectRequestedBy")

  @@map("vendors")
}

// ─── 3. Projects ─────────────────────────────────────────────────────────────

model Project {
  id                 Int             @id @default(autoincrement())
  name               String
  description        String?
  status             ProjectStatus   @default(DRAFT)
  approvalStatus     ProjectApproval @default(PENDING)
  priority           Priority        @default(MEDIUM)
  billingMethod      BillingMethod   @default(HOURLY)
  startDate          DateTime?
  endDate            DateTime?
  proposedCost       Decimal?        @db.Decimal(12, 2)
  estimatedHours     Decimal?        @db.Decimal(8, 2)
  proposedWorkers    Int?
  hourlyRate         Decimal?        @db.Decimal(10, 2)
  category           String?
  riskLevel          RiskLevel?
  requiredSkillSet   String?
  createdAt          DateTime        @default(now())

  client   Client? @relation(fields: [clientId], references: [id])
  clientId Int?
  createdBy   User @relation("ProjectCreatedBy", fields: [createdById], references: [id])
  createdById Int
  requestingVendor   Vendor? @relation("ProjectRequestedBy", fields: [requestingVendorId], references: [id])
  requestingVendorId Int?

  assignments   ProjectAssignment[]
  members       ProjectMember[]
  invoiceSettings ProjectInvoiceSetting?
  milestones    Milestone[]
  tasks         Task[]
  timeEntries   TimeEntry[]
  vendorQuotes  VendorQuote[]
  budgets       Budget[]
  invoices      Invoice[]
  billingRates  BillingRate[]

  @@map("projects")
}

enum ProjectStatus {
  DRAFT
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
  ARCHIVED
}

enum BillingMethod {
  FIXED
  HOURLY
  MIXED
}

enum ProjectApproval {
  PENDING
  APPROVED
  REJECTED
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
}

model ProjectAssignment {
  id             Int            @id @default(autoincrement())
  assignmentRole AssignmentRole
  createdAt      DateTime       @default(now())

  project      Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId    Int
  user         User    @relation("AssignmentUser", fields: [userId], references: [id])
  userId       Int
  assignedBy   User    @relation("AssignmentAssignedBy", fields: [assignedById], references: [id])
  assignedById Int

  @@unique([projectId, userId, assignmentRole])
  @@map("project_assignments")
}

enum AssignmentRole {
  ACCOUNT_MANAGER
  PROJECT_MANAGER
}

model ProjectMember {
  id          Int      @id @default(autoincrement())
  hourlyRate  Decimal? @db.Decimal(10, 2)
  isBillable  Boolean  @default(true)
  createdAt   DateTime @default(now())

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId Int
  user      User    @relation(fields: [userId], references: [id])
  userId    Int

  @@unique([projectId, userId])
  @@map("project_members")
}

model ProjectInvoiceSetting {
  id           Int          @id @default(autoincrement())
  triggerType  TriggerType  @default(MANUAL)
  billingCycle BillingCycle @default(MONTHLY)

  project           Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId         Int     @unique
  billingContact    User    @relation(fields: [billingContactId], references: [id])
  billingContactId  Int

  @@map("project_invoice_settings")
}

enum TriggerType {
  MANUAL
  MILESTONE
  PERIODIC
  MIXED
}

enum InvoiceType {
  CLIENT
  VENDOR
}

enum BillingCycle {
  WEEKLY
  BIWEEKLY
  MONTHLY
}

// ─── 4. Milestones ───────────────────────────────────────────────────────────

model Milestone {
  id              Int             @id @default(autoincrement())
  name            String
  description     String?
  dueDate         DateTime?
  status          MilestoneStatus @default(PENDING)
  triggersInvoice Boolean         @default(false)
  completedAt     DateTime?
  createdAt       DateTime        @default(now())

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId Int

  tasks           Task[]
  invoices        Invoice[]
  invoiceLineItems InvoiceLineItem[]
  vendorQuotes    VendorQuote[]

  @@map("milestones")
}

enum MilestoneStatus {
  PENDING
  COMPLETED
}

// ─── 5. Tasks ────────────────────────────────────────────────────────────────

model Task {
  id             Int        @id @default(autoincrement())
  name           String
  description    String?
  status         TaskStatus @default(TODO)
  priority       Priority   @default(MEDIUM)
  dueDate        DateTime?
  estimatedHours Decimal?   @db.Decimal(6, 2)
  isBillable     Boolean    @default(true)
  createdAt      DateTime   @default(now())

  project      Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId    Int
  milestone    Milestone? @relation(fields: [milestoneId], references: [id])
  milestoneId  Int?
  parentTask   Task?      @relation("Subtasks", fields: [parentTaskId], references: [id])
  parentTaskId Int?
  subtasks     Task[]     @relation("Subtasks")
  assignee     User?      @relation("TaskAssignee", fields: [assigneeId], references: [id])
  assigneeId   Int?
  assignedBy   User?      @relation("TaskAssignedBy", fields: [assignedById], references: [id])
  assignedById Int?
  createdBy    User       @relation("TaskCreatedBy", fields: [createdById], references: [id])
  createdById  Int

  timeEntries      TimeEntry[]
  vendorQuotes     VendorQuote[]
  budgets          Budget[]
  invoiceLineItems InvoiceLineItem[]

  @@map("tasks")
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  DONE
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// ─── 6. Vendor Quotes & Budgets ──────────────────────────────────────────────

model VendorQuote {
  id              Int         @id @default(autoincrement())
  quotedPrice     Decimal     @db.Decimal(12, 2)
  estimatedHours  Decimal?    @db.Decimal(8, 2)
  peopleCount     Int?
  status          QuoteStatus @default(PENDING)
  version         Int         @default(1)
  expiryDate      DateTime?
  rejectionReason String?
  reviewedAt      DateTime?
  createdAt       DateTime    @default(now())
  hourlyRate      Decimal?    @db.Decimal(10, 2)
  paymentMode     PaymentMode @default(TASK)

  vendor       Vendor  @relation(fields: [vendorId], references: [id])
  vendorId     Int
  project      Project? @relation(fields: [projectId], references: [id])
  projectId    Int?
  task         Task?    @relation(fields: [taskId], references: [id])
  taskId       Int?
  milestoneId  Int?
  milestone    Milestone?  @relation(fields: [milestoneId], references: [id])
  submittedBy  User    @relation("QuoteSubmittedBy", fields: [submittedById], references: [id])
  submittedById Int
  reviewedBy   User?   @relation("QuoteReviewedBy", fields: [reviewedById], references: [id])
  reviewedById Int?
  invoices     Invoice[]

  @@map("vendor_quotes")
}

enum QuoteStatus {
  PENDING
  SUBMITTED
  APPROVED
  REJECTED
}

enum PaymentMode {
  MILESTONE
  TASK
}

model Budget {
  id        Int      @id @default(autoincrement())
  amount    Decimal  @db.Decimal(12, 2)
  notes     String?
  createdAt DateTime @default(now())

  project    Project? @relation(fields: [projectId], references: [id])
  projectId  Int?
  task       Task?    @relation(fields: [taskId], references: [id])
  taskId     Int?
  enteredBy  User     @relation(fields: [enteredById], references: [id])
  enteredById Int

  @@map("budgets")
}

// ─── 7. Time Tracking ────────────────────────────────────────────────────────

model Timesheet {
  id              Int             @id @default(autoincrement())
  periodStart     DateTime
  periodEnd       DateTime
  status          TimesheetStatus @default(DRAFT)
  rejectionReason String?
  createdAt       DateTime        @default(now())

  user         User  @relation(fields: [userId], references: [id])
  userId       Int
  reviewedBy   User? @relation("TimesheetReviewedBy", fields: [reviewedById], references: [id])
  reviewedById Int?

  timeEntries TimeEntry[]

  @@map("timesheets")
}

enum TimesheetStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}

model TimeEntry {
  id              Int      @id @default(autoincrement())
  date            DateTime @db.Date
  startTime       DateTime @db.Time
  endTime         DateTime @db.Time
  durationMinutes Int
  description     String?
  isBillable      Boolean  @default(true)
  isBilled        Boolean  @default(false)
  isLocked        Boolean  @default(false)
  createdAt       DateTime @default(now())

  timesheet   Timesheet? @relation(fields: [timesheetId], references: [id])
  timesheetId Int?
  user        User       @relation(fields: [userId], references: [id])
  userId      Int
  project     Project    @relation(fields: [projectId], references: [id])
  projectId   Int
  task        Task?      @relation(fields: [taskId], references: [id])
  taskId      Int?

  invoiceLineItems InvoiceLineItem[]

  @@map("time_entries")
}

// ─── 8. Billing Rates ────────────────────────────────────────────────────────

model BillingRate {
  id            Int      @id @default(autoincrement())
  rateType      RateType
  hourlyRate    Decimal  @db.Decimal(10, 2)
  effectiveFrom DateTime
  effectiveTo   DateTime?
  createdAt     DateTime @default(now())

  vendor    Vendor?  @relation(fields: [vendorId], references: [id])
  vendorId  Int?
  project   Project? @relation(fields: [projectId], references: [id])
  projectId Int?
  user      User?    @relation(fields: [userId], references: [id])
  userId    Int?

  @@map("billing_rates")
}

enum RateType {
  GLOBAL
  VENDOR
  PROJECT
  USER
}

// ─── 9. Invoicing ────────────────────────────────────────────────────────────

model Invoice {
  id             Int           @id @default(autoincrement())
  status         InvoiceStatus @default(DRAFT)
  triggerType    TriggerType?
  invoiceDate    DateTime
  dueDate        DateTime
  subtotal       Decimal       @db.Decimal(12, 2)
  taxRate        Decimal       @default(0) @db.Decimal(5, 2)
  taxAmount      Decimal       @db.Decimal(12, 2)
  total          Decimal       @db.Decimal(12, 2)
  notes          String?
  sentAt         DateTime?
  paidAt         DateTime?
  createdAt      DateTime      @default(now())
  invoiceType    InvoiceType   @default(CLIENT)
  approvedAt     DateTime?
  rejectionNote  String?

  client        Client?    @relation(fields: [clientId], references: [id])
  clientId      Int?
  project       Project?   @relation(fields: [projectId], references: [id])
  projectId     Int?
  milestone     Milestone? @relation(fields: [milestoneId], references: [id])
  milestoneId   Int?
  createdBy     User       @relation(fields: [createdById], references: [id])
  createdById   Int
  vendor        Vendor?    @relation(fields: [vendorId], references: [id])
  vendorId      Int?
  vendorQuote   VendorQuote? @relation(fields: [vendorQuoteId], references: [id])
  vendorQuoteId Int?
  approvedBy    User?      @relation("InvoiceApprovedBy", fields: [approvedById], references: [id])
  approvedById  Int?

  lineItems InvoiceLineItem[]
  payments  Payment[]

  @@map("invoices")
}

enum InvoiceStatus {
  DRAFT
  SUBMITTED
  SENT
  APPROVED
  REJECTED
  PAID
  OVERDUE
}

enum LineItemType {
  HOURLY
  FIXED
  EXPENSE
  ADJUSTMENT
}

model InvoiceLineItem {
  id          Int          @id @default(autoincrement())
  description String
  quantity    Decimal      @db.Decimal(8, 2)
  unitPrice   Decimal      @db.Decimal(10, 2)
  amount      Decimal      @db.Decimal(12, 2)
  lineItemType LineItemType @default(FIXED)

  invoice     Invoice    @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  invoiceId   Int
  task        Task?      @relation(fields: [taskId], references: [id])
  taskId      Int?
  milestone   Milestone? @relation(fields: [milestoneId], references: [id])
  milestoneId Int?
  timeEntry   TimeEntry? @relation(fields: [timeEntryId], references: [id])
  timeEntryId Int?       @unique

  @@map("invoice_line_items")
}

model Payment {
  id            Int      @id @default(autoincrement())
  amount        Decimal  @db.Decimal(12, 2)
  paymentDate   DateTime
  paymentMethod String
  reference     String?
  createdAt     DateTime @default(now())

  invoice    Invoice @relation(fields: [invoiceId], references: [id])
  invoiceId  Int
  recordedBy User    @relation(fields: [recordedById], references: [id])
  recordedById Int

  @@map("payments")
}
